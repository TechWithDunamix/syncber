---
import { getLocaleFromUrl } from "@/docs/js/localeUtils";
import { getTranslatedData } from "@/docs/js/translationUtils";
import DocsLandingLayout from "@/docs/layouts/DocsLandingLayout.astro";

const currLocale = getLocaleFromUrl(Astro.url);
const siteData = getTranslatedData("siteData", currLocale);
---

<DocsLandingLayout title="Sign Up — Skillber" description="Create your Skillber account.">
  <main class="flex flex-1 items-center justify-center px-4 py-24">
    <div class="w-full max-w-sm">
      <div class="mb-8 text-center">
        <h1 class="font-heading text-foreground mb-2 text-3xl font-medium tracking-wide">
          Create Your Account
        </h1>
        <p class="text-muted-foreground text-sm">Start building in-demand tech skills today</p>
      </div>

      <form id="signup-form" class="space-y-5" novalidate method="post">
        <div>
          <label for="name" class="text-foreground mb-1.5 block text-sm font-medium">Full Name</label>
          <input
            type="text"
            id="name"
            name="name"
            required
            placeholder="John Doe"
            class="border-input bg-background text-foreground placeholder:text-muted-foreground focus:border-accent focus:ring-accent/20 w-full rounded-lg border px-4 py-2.5 text-sm transition-colors focus:ring-4 focus:outline-none"
          />
        </div>

        <div>
          <label for="email" class="text-foreground mb-1.5 block text-sm font-medium">Email</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            placeholder="you@example.com"
            class="border-input bg-background text-foreground placeholder:text-muted-foreground focus:border-accent focus:ring-accent/20 w-full rounded-lg border px-4 py-2.5 text-sm transition-colors focus:ring-4 focus:outline-none"
          />
        </div>

        <div>
          <label for="password" class="text-foreground mb-1.5 block text-sm font-medium">Password</label>
          <input
            type="password"
            id="password"
            name="password"
            required
            minlength={6}
            placeholder="At least 6 characters"
            class="border-input bg-background text-foreground placeholder:text-muted-foreground focus:border-accent focus:ring-accent/20 w-full rounded-lg border px-4 py-2.5 text-sm transition-colors focus:ring-4 focus:outline-none"
          />
        </div>

        <p id="signup-error" class="hidden rounded-lg bg-error/10 p-3 text-sm font-medium text-error"></p>

        <button
          type="submit"
          id="signup-btn"
          class="bg-accent text-accent-foreground hover:bg-accent/90 inline-flex w-full items-center justify-center gap-2 rounded-full px-4 py-2.5 text-sm font-medium transition-colors disabled:opacity-50"
        >
          Create Account
        </button>
      </form>

      <p class="text-muted-foreground mt-6 text-center text-sm">
        Already have an account?&nbsp;
        <a href="/login" class="text-accent hover:text-accent/80 font-medium transition-colors">Log in</a>
      </p>
    </div>
  </main>
</DocsLandingLayout>

<script>
  import { signup } from "@/docs/services/auth";

  document.getElementById("signup-form")?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const btn = document.getElementById("signup-btn") as HTMLButtonElement;
    const errorEl = document.getElementById("signup-error") as HTMLParagraphElement;
    const name = (document.getElementById("name") as HTMLInputElement).value;
    const email = (document.getElementById("email") as HTMLInputElement).value;
    const password = (document.getElementById("password") as HTMLInputElement).value;

    errorEl.classList.add("hidden");
    btn.disabled = true;
    btn.textContent = "Creating account...";

    const result = await signup(name, email, password);

    if (result.success && result.data) {
      const params = new URLSearchParams(window.location.search);
      const redirect = params.get("redirect") || "/my-courses";
      window.location.href = redirect;
    } else {
      errorEl.textContent = result.error || "Signup failed. Please try again.";
      errorEl.classList.remove("hidden");
      btn.disabled = false;
      btn.textContent = "Create Account";
    }
  });
</script>
