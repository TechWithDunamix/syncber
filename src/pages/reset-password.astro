---
import { getLocaleFromUrl } from "@/docs/js/localeUtils";
import { getTranslatedData } from "@/docs/js/translationUtils";
import DocsLandingLayout from "@/docs/layouts/DocsLandingLayout.astro";

const currLocale = getLocaleFromUrl(Astro.url);
const siteData = getTranslatedData("siteData", currLocale);
---

<DocsLandingLayout title="Reset Password — Skillber" description="Set a new password for your Skillber account.">
  <main class="flex flex-1 items-center justify-center px-4 py-24">
    <div class="w-full max-w-sm">
      <div class="mb-8 text-center">
        <h1 class="font-heading text-foreground mb-2 text-3xl font-medium tracking-wide" id="reset-title">
          Set New Password
        </h1>
        <p id="reset-subtitle" class="text-muted-foreground text-sm">
          Choose a new password for your account
        </p>
      </div>

      <!-- Loading state while Supabase processes the recovery token -->
      <div id="reset-loading" class="text-center py-8">
        <div class="mx-auto mb-4 h-8 w-8 animate-spin rounded-full border-4 border-accent border-t-transparent"></div>
        <p class="text-muted-foreground text-sm">Verifying your reset link...</p>
      </div>

      <!-- Error state if the recovery link is invalid/expired -->
      <div id="reset-invalid" class="hidden text-center py-8">
        <div class="mb-4 mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-error/10">
          <svg class="h-8 w-8 text-error" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 9v4m0 4h.01M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <p class="text-foreground font-medium mb-2">Invalid or expired reset link</p>
        <p class="text-muted-foreground text-sm mb-6">This password reset link is no longer valid. Please request a new one.</p>
        <a href="/forgot-password" class="bg-accent text-accent-foreground hover:bg-accent/90 inline-flex items-center justify-center gap-2 rounded-full px-6 py-2.5 text-sm font-medium transition-colors">
          Request New Link
        </a>
      </div>

      <!-- Password reset form (shown after recovery token is verified) -->
      <form id="reset-form" class="hidden space-y-5" novalidate method="post">
        <div>
          <label for="password" class="text-foreground mb-1.5 block text-sm font-medium">New Password</label>
          <input
            type="password"
            id="password"
            name="password"
            required
            minlength={6}
            placeholder="At least 6 characters"
            class="border-input bg-background text-foreground placeholder:text-muted-foreground focus:border-accent focus:ring-accent/20 w-full rounded-lg border px-4 py-2.5 text-sm transition-colors focus:ring-4 focus:outline-none"
          />
        </div>

        <div>
          <label for="confirm-password" class="text-foreground mb-1.5 block text-sm font-medium">Confirm Password</label>
          <input
            type="password"
            id="confirm-password"
            name="confirm-password"
            required
            minlength={6}
            placeholder="Repeat your password"
            class="border-input bg-background text-foreground placeholder:text-muted-foreground focus:border-accent focus:ring-accent/20 w-full rounded-lg border px-4 py-2.5 text-sm transition-colors focus:ring-4 focus:outline-none"
          />
        </div>

        <p id="reset-error" class="hidden rounded-lg bg-error/10 p-3 text-sm font-medium text-error"></p>
        <p id="reset-success" class="hidden rounded-lg bg-emerald-500/10 p-3 text-sm font-medium text-emerald-500"></p>

        <button
          type="submit"
          id="reset-btn"
          class="bg-accent text-accent-foreground hover:bg-accent/90 inline-flex w-full items-center justify-center gap-2 rounded-full px-4 py-2.5 text-sm font-medium transition-colors disabled:opacity-50"
        >
          Reset Password
        </button>
      </form>

      <p class="text-muted-foreground mt-6 text-center text-sm" id="back-link">
        <a href="/login" class="text-accent hover:text-accent/80 font-medium transition-colors">Back to login</a>
      </p>
    </div>
  </main>
</DocsLandingLayout>

<script>
  import { onRecoveryReady, resetPassword } from "@/docs/services/auth";
  import { requireSupabase } from "@/docs/services/supabase";

  document.addEventListener("DOMContentLoaded", async () => {
    const loadingEl = document.getElementById("reset-loading")!;
    const invalidEl = document.getElementById("reset-invalid")!;
    const form = document.getElementById("reset-form") as HTMLFormElement;
    const btn = document.getElementById("reset-btn") as HTMLButtonElement;
    const errorEl = document.getElementById("reset-error") as HTMLParagraphElement;
    const successEl = document.getElementById("reset-success") as HTMLParagraphElement;
    const titleEl = document.getElementById("reset-title")!;
    const subtitleEl = document.getElementById("reset-subtitle")!;

    // Check if we have a recovery token in the URL hash
    const hash = window.location.hash;
    const hasRecoveryHash = hash && hash.includes("type=recovery");

    if (!hasRecoveryHash) {
      // No recovery token — the user likely navigated here directly
      loadingEl.classList.add("hidden");
      invalidEl.classList.remove("hidden");
      return;
    }

    // Wait for Supabase to process the recovery token and create a session
    // This resolves when Supabase fires SIGNED_IN / PASSWORD_RECOVERY
    let sessionReady = false;

    onRecoveryReady(() => {
      sessionReady = true;
      loadingEl.classList.add("hidden");
      form.classList.remove("hidden");
      titleEl.textContent = "Set New Password";
      subtitleEl.textContent = "Choose a new password for your account";
    });

    // Also try to get the session directly in case onAuthStateChange already fired
    const sb = requireSupabase();
    const { data: { session } } = await sb.auth.getSession();
    if (session) {
      sessionReady = true;
      loadingEl.classList.add("hidden");
      form.classList.remove("hidden");
    }

    // If after a timeout the session isn't ready, show the invalid link message
    setTimeout(() => {
      if (!sessionReady) {
        loadingEl.classList.add("hidden");
        invalidEl.classList.remove("hidden");
      }
    }, 8000);

    // Handle form submission
    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      const password = (document.getElementById("password") as HTMLInputElement).value;
      const confirm = (document.getElementById("confirm-password") as HTMLInputElement).value;

      errorEl.classList.add("hidden");
      successEl.classList.add("hidden");

      if (password !== confirm) {
        errorEl.textContent = "Passwords do not match.";
        errorEl.classList.remove("hidden");
        return;
      }

      if (password.length < 6) {
        errorEl.textContent = "Password must be at least 6 characters.";
        errorEl.classList.remove("hidden");
        return;
      }

      btn.disabled = true;
      btn.textContent = "Resetting...";

      const result = await resetPassword(password);

      if (result.success) {
        successEl.textContent = "Password reset successfully! Redirecting to login...";
        successEl.classList.remove("hidden");
        btn.textContent = "Done!";
        setTimeout(() => {
          window.location.href = "/login";
        }, 2000);
      } else {
        errorEl.textContent = result.error || "Failed to reset password. Please try again.";
        errorEl.classList.remove("hidden");
        btn.disabled = false;
        btn.textContent = "Reset Password";
      }
    });
  });
</script>
