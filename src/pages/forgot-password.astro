---
import { getLocaleFromUrl } from "@/docs/js/localeUtils";
import { getTranslatedData } from "@/docs/js/translationUtils";
import DocsLandingLayout from "@/docs/layouts/DocsLandingLayout.astro";

const currLocale = getLocaleFromUrl(Astro.url);
const siteData = getTranslatedData("siteData", currLocale);
---

<DocsLandingLayout title="Forgot Password — Skillber" description="Reset your Skillber account password.">
  <main class="flex flex-1 items-center justify-center px-4 py-24">
    <div class="w-full max-w-sm">
      <div class="mb-8 text-center">
        <h1 class="font-heading text-foreground mb-2 text-3xl font-medium tracking-wide">
          Forgot Password
        </h1>
        <p class="text-muted-foreground text-sm">
          Enter your email and we'll send you a reset link
        </p>
      </div>

      <form id="forgot-form" class="space-y-5" novalidate method="post">
        <div>
          <label for="email" class="text-foreground mb-1.5 block text-sm font-medium">Email</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            placeholder="you@example.com"
            class="border-input bg-background text-foreground placeholder:text-muted-foreground focus:border-accent focus:ring-accent/20 w-full rounded-lg border px-4 py-2.5 text-sm transition-colors focus:ring-4 focus:outline-none"
          />
        </div>

        <p id="forgot-error" class="hidden rounded-lg bg-error/10 p-3 text-sm font-medium text-error"></p>
        <p id="forgot-success" class="hidden rounded-lg bg-emerald-500/10 p-3 text-sm font-medium text-emerald-500"></p>

        <button
          type="submit"
          id="forgot-btn"
          class="bg-accent text-accent-foreground hover:bg-accent/90 inline-flex w-full items-center justify-center gap-2 rounded-full px-4 py-2.5 text-sm font-medium transition-colors disabled:opacity-50"
        >
          Send Reset Link
        </button>
      </form>

      <p class="text-muted-foreground mt-6 text-center text-sm">
        <a href="/login" class="text-accent hover:text-accent/80 font-medium transition-colors">Back to login</a>
      </p>
    </div>
  </main>
</DocsLandingLayout>

<script>
  import { forgotPassword } from "@/docs/services/auth";

  document.getElementById("forgot-form")?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const btn = document.getElementById("forgot-btn") as HTMLButtonElement;
    const errorEl = document.getElementById("forgot-error") as HTMLParagraphElement;
    const successEl = document.getElementById("forgot-success") as HTMLParagraphElement;
    const email = (document.getElementById("email") as HTMLInputElement).value;

    errorEl.classList.add("hidden");
    successEl.classList.add("hidden");
    btn.disabled = true;
    btn.textContent = "Sending...";

    const result = await forgotPassword(email);

    if (result.success) {
      successEl.textContent = "Check your email for a password reset link.";
      successEl.classList.remove("hidden");
      btn.textContent = "Link Sent";
    } else {
      errorEl.textContent = result.error || "Failed to send reset email. Please try again.";
      errorEl.classList.remove("hidden");
      btn.disabled = false;
      btn.textContent = "Send Reset Link";
    }
  });
</script>
