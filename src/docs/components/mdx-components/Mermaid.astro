---
interface Props {
  code: string;
}

const { code } = Astro.props as Props;
---

<div class="mermaid-wrapper not-content my-6 flex justify-center">
  <pre class="mermaid not-content overflow-x-auto rounded-lg bg-transparent p-4">
    {code}
  </pre>
</div>

<script>
  /**
   * Initialises Mermaid on the client once the DOM is ready.
   * Uses a singleton guard so the library is only loaded once regardless of
   * how many <Mermaid> components are on the page.
   */
  (async function initMermaid() {
    if (document.querySelector("script[data-mermaid-loaded]")) return;

    const script = document.createElement("script");
    script.src = "https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.min.js";
    script.dataset.mermaidLoaded = "true";
    script.onload = () => {
      window.mermaid.initialize({
        startOnLoad: true,
        theme: document.documentElement.classList.contains("dark")
          ? "dark"
          : "default",
        securityLevel: "loose",
        fontFamily: "inherit",
      });
      window.mermaid.run({ querySelector: ".mermaid" });
    };
    document.head.appendChild(script);
  })();
</script>

<style>
  .mermaid-wrapper svg {
    max-width: 100%;
    height: auto;
  }
</style>
