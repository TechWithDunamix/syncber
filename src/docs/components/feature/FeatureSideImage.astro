---
/**
 * * These are alternating side cards with titles, text, and images
 * Recommend using 2 or 3 cards in a row
 */
import infraSecImg from "@images/feature/infrastructure-security.png";
import leaderMgmtImg from "@images/feature/leadership-management.png";
import fullStackImg from "@images/feature/full-stack-creator.png";
import cyberDefenseImg from "@images/feature/cyber-defense-analytics.png";

import { docsRoute } from "@/docs/js/docsUtils";
import FeatureCard from "./FeatureCardSideImage.astro";

interface FeatureItem {
  image: ImageMetadata; // an imported image
  title: string;
  description: string;
  href: string; // link to learn more
  buttonText: string; // button text
}

const featureData: FeatureItem[] = [
  {
    image: infraSecImg,
    title: "Cybersecurity & Cloud Engineering",
    description:
      "Master threat detection, incident response, cloud security architecture, and IAM/PAM. Build resilient, zero-trust infrastructure with hands-on labs and real-world scenarios.",
    href: `/${docsRoute}/infrastructure-security/`,
    buttonText: "View Course",
  },
  {
    image: leaderMgmtImg,
    title: "Full Stack Development",
    description:
      "From frontend to backend, learn to build complete applications with modern frameworks, APIs, databases, and deployment workflows. Python, JavaScript, React, Node.js, and more.",
    href: `/${docsRoute}/full-stack-creator/`,
    buttonText: "View Course",
  },
  {
    image: fullStackImg,
    title: "Data Science & AI",
    description:
      "Dive into machine learning, data analysis, and AI engineering. Covering Python, pandas, scikit-learn, TensorFlow, LLMs, and production ML pipelines.",
    href: `/${docsRoute}/full-stack-creator/`,
    buttonText: "View Course",
  },
  {
    image: cyberDefenseImg,
    title: "DevOps & Platform Engineering",
    description:
      "Learn CI/CD, containerization, Kubernetes, infrastructure as code, and site reliability engineering. Automate everything and ship reliably at scale.",
    href: `/${docsRoute}/cyber-defense-analytics/`,
    buttonText: "View Course",
  },
];
---

<section id="feature-side-image" class="my-12 overflow-hidden py-6 md:py-12">
  <div class="docs-home-container">
    <div class="flex flex-col gap-16 md:gap-24">
      {
        featureData.map((feature, idx) => (
          <FeatureCard
            title={feature.title}
            description={feature.description}
            image={feature.image}
            imageSide={idx % 2 === 0 ? "right" : "left"}
            href={feature.href}
            buttonText={feature.buttonText}
          />
        ))
      }
    </div>
  </div>
</section>
