---
import ChevronDown from "@tabler/icons/outline/chevron-down.svg";

import type { navDropdownItem } from "@/docs/config/types/configDataTypes";
import { getLocaleFromUrl } from "@/docs/js/localeUtils";
import { getLocalizedRoute } from "@/docs/js/translationUtils";

interface Props {
  item: navDropdownItem;
}

const { item } = Astro.props;
const currLocale = getLocaleFromUrl(Astro.url);
---

<div class="group relative">
  <button
    class="docs-primary-focus docs-nav__link--base relative flex h-8 cursor-pointer items-center justify-center gap-1 px-2"
    aria-expanded="false"
    aria-haspopup="true"
  >
    {item.text}
    <ChevronDown
      class="size-3.5 transition-transform duration-200 group-hover:rotate-180"
      aria-hidden="true"
    />
  </button>

  <div
    class="invisible absolute top-full left-1/2 z-50 w-64 -translate-x-1/2 translate-y-2 opacity-0 shadow-lg transition-all duration-200 group-hover:visible group-hover:translate-y-0 group-hover:opacity-100"
  >
    <div
      class="bg-background mt-2 rounded-xl border p-2"
    >
      {
        item.items.map((dropdownItem) => {
          const actualLink = dropdownItem.link.startsWith("/")
            ? getLocalizedRoute(currLocale, dropdownItem.link)
            : dropdownItem.link;

          return (
            <a
              href={actualLink}
              class="docs-primary-focus hover:bg-accent/10 flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm transition-colors"
              {...(dropdownItem.newTab && { target: "_blank", rel: "noopener noreferrer" })}
            >
              <div class="flex flex-col">
                <span class="font-medium">{dropdownItem.text}</span>
              </div>
            </a>
          );
        })
      }
    </div>
  </div>
</div>
