---
// icons
import Menu from "@tabler/icons/outline/menu-2.svg";

import CoursesDropdown from "@/docs/components/nav/CoursesDropdown.astro";
import DocsLogo from "@/docs/components/docs-logo/DocsLogo.astro";
import LanguageSelect from "@/docs/components/language-select/LanguageSelect.astro";
import MobileLanguageSelect from "@/docs/components/language-select/MobileLanguageSelect.astro";
import NavLink from "@/docs/components/nav/NavLink.astro";
import SidebarNav from "@/docs/components/nav/SidebarNav.astro";
import Search from "@/docs/components/search/Search.astro";
import SocialIconNav from "@/docs/components/social/SocialIconNav.astro";
import ThemeToggle from "@/docs/components/theme-toggle/ThemeToggle.astro";
import type { navDropdownItem } from "@/docs/config/types/configDataTypes";
import { locales } from "@/docs/config/siteSettings.json";
import { getLocaleFromUrl } from "@/docs/js/localeUtils";
import { getLocalizedRoute } from "@/docs/js/translationUtils";
import { getTranslatedData } from "@/docs/js/translationUtils";

import { Dialog, DialogContent, DialogTrigger } from "./nav-dialog";

interface Props {
  tabId?: string;
}

const { tabId = "main" } = Astro.props;
const currLocale = getLocaleFromUrl(Astro.url);
const navData = getTranslatedData("navData", currLocale);
const siteData = getTranslatedData("siteData", currLocale);
---

<div class="flex h-(--nav-height) items-center px-4">
  {/* Rest of the navbar */}
  <nav class="flex flex-1 items-center justify-between">
    <div class="ml-1 flex items-center space-x-6">
      <DocsLogo />
    </div>
    <div class="flex items-center">
      <div class="hidden lg:flex">
        <ul class="hidden items-center space-x-3 md:flex">
          {
            navData.map((navItem) => {
              const isDropdown = "items" in navItem;
              return (
                <li>
                  {isDropdown ? (
                    <CoursesDropdown item={navItem as navDropdownItem} />
                  ) : (
                    <NavLink navItem={navItem} class="px-2" />
                  )}
                </li>
              );
            })
          }
        </ul>

        <div class="bg-border mx-6 h-8 w-px"></div>
      </div>

      <div class="flex items-center space-x-2">
        <Search />

        {
          siteData.navSocials && siteData.navSocials.length > 0 && (
            <div class="flex items-center space-x-2">
              {siteData.navSocials?.map((social) => (
                <SocialIconNav {...social} size="md" />
              ))}
            </div>
          )
        }

        <ThemeToggle class="hidden md:flex" size="md" />

        {locales.length > 1 && <LanguageSelect class="ml-1 hidden md:flex" />}

        <!-- Auth buttons -->
        <div id="auth-desktop" class="ml-3 hidden items-center gap-2 md:flex">
          <a
            href="/login"
            class="docs-primary-focus text-foreground hover:text-accent rounded-lg px-3 py-1.5 text-sm font-medium transition-colors"
          >
            Log In
          </a>
          <a
            href="/signup"
            id="signup-btn-desktop"
            class="bg-accent text-accent-foreground hover:brightness-110 rounded-lg px-4 py-1.5 text-sm font-semibold shadow-sm transition-all"
          >
            Create Account
          </a>
          <a
            href="/my-courses"
            id="my-courses-btn-desktop"
            class="bg-accent text-accent-foreground hover:brightness-110 hidden rounded-lg px-4 py-1.5 text-sm font-semibold shadow-sm transition-all"
          >
            My Courses
          </a>
          <button
            id="logout-btn-desktop"
            class="text-muted-foreground hover:text-foreground hidden cursor-pointer rounded-lg px-3 py-1.5 text-sm font-medium transition-colors"
          >
            Log Out
          </button>
        </div>
      </div>
    </div>
  </nav>
  {/* Mobile Sidebar Dialog */}
  <Dialog>
    <DialogTrigger aria-label="Toggle Menu" class="docs-nav__link--base mr-1 p-1.5 md:hidden">
      <Menu class="size-6" />
    </DialogTrigger>
    <DialogContent
      animationDuration={300}
      class="h-[calc(100vh-var(--nav-height))-1px] rounded-none"
    >
      <div class="overflow-x-hidden overflow-y-auto">
        <SidebarNav tabId={tabId}>
          <div slot="after-links" class="flex justify-between">
            <ThemeToggle />
            {locales.length > 1 && <MobileLanguageSelect />}
          </div>
          <div slot="after-links" id="auth-mobile" class="mt-4 flex flex-col gap-2 border-t pt-4">
            <a href="/login" class="docs-nav__link--base rounded-lg px-3 py-2 text-sm font-medium">
              Log In
            </a>
            <a
              href="/signup"
              id="signup-btn-mobile"
              class="bg-accent text-accent-foreground hover:brightness-110 rounded-lg px-3 py-2 text-center text-sm font-semibold transition-all"
            >
              Create Account
            </a>
            <a
              href="/my-courses"
              id="my-courses-btn-mobile"
              class="docs-nav__link--base hidden rounded-lg px-3 py-2 text-sm font-medium"
            >
              My Courses
            </a>
            <button
              id="logout-btn-mobile"
              class="text-muted-foreground hover:text-foreground hidden cursor-pointer rounded-lg px-3 py-2 text-left text-sm font-medium transition-colors"
            >
              Log Out
            </button>
          </div>
        </SidebarNav>
      </div>
    </DialogContent>
  </Dialog>
</div>

<script>
  import { getCurrentSession, logout, refreshSession } from "@/docs/services/auth";

  async function updateAuthUI() {
    await refreshSession();
    const session = getCurrentSession();
    const isLoggedIn = !!session;

    // Desktop
    document.querySelectorAll("#auth-desktop a[href='/login']").forEach((el) => el.classList.toggle("hidden", isLoggedIn));
    document.getElementById("signup-btn-desktop")?.classList.toggle("hidden", isLoggedIn);
    document.getElementById("my-courses-btn-desktop")?.classList.toggle("hidden", !isLoggedIn);
    document.getElementById("logout-btn-desktop")?.classList.toggle("hidden", !isLoggedIn);

    // Mobile
    document.querySelectorAll("#auth-mobile a[href='/login']").forEach((el) => el.classList.toggle("hidden", isLoggedIn));
    document.getElementById("signup-btn-mobile")?.classList.toggle("hidden", isLoggedIn);
    document.getElementById("my-courses-btn-mobile")?.classList.toggle("hidden", !isLoggedIn);
    document.getElementById("logout-btn-mobile")?.classList.toggle("hidden", !isLoggedIn);
  }

  document.getElementById("logout-btn-desktop")?.addEventListener("click", () => {
    logout();
    window.location.href = "/";
  });
  document.getElementById("logout-btn-mobile")?.addEventListener("click", () => {
    logout();
    window.location.href = "/";
  });

  updateAuthUI();
</script>
